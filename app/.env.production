# ============================================
# GiftCard Pro - Production Environment
# ============================================

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://giftcard_pro_user:giftcard_secure_pass_2024@localhost:5432/giftcard_platform?schema=public"

# JWT Configuration
JWT_SECRET="gcp_jwt_secret_key_2024_secure_random_string_for_production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="gcp_refresh_secret_key_2024_secure_random_string_for_refresh"

# Server Configuration
PORT=5000
NODE_ENV="production"
FRONTEND_URL="https://giftcardpro.app"
API_URL="https://api.giftcardpro.app"

# Email Configuration (SendGrid)
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"
EMAIL_FROM="noreply@giftcardpro.com"
EMAIL_FROM_NAME="GiftCard Pro"

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID="AC_your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# TRON Blockchain Configuration
TRON_API_KEY="your_tron_api_key_here"
TRON_FULL_NODE="https://api.trongrid.io"
TRON_SOLIDITY_NODE="https://api.trongrid.io"
TRON_EVENT_SERVER="https://api.trongrid.io"
USDT_TRC20_CONTRACT="TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t"

# OPAY Configuration
OPAY_MERCHANT_ID="your_opay_merchant_id"
OPAY_API_KEY="your_opay_api_key"
OPAY_API_SECRET="your_opay_api_secret"
OPAY_BASE_URL="https://api.opay-inc.com"
OPAY_VIRTUAL_ACCOUNT="9027360225"

# OpenAI Configuration (for AI features)
OPENAI_API_KEY="sk-your_openai_api_key_here"
OPENAI_MODEL="gpt-4"

# CoinGecko API
COINGECKO_API_KEY="your_coingecko_api_key"

# Admin Configuration
ADMIN_ACCESS_CODE="1122"
DEFAULT_ADMIN_EMAIL="admin@giftcardpro.com"
DEFAULT_ADMIN_PASSWORD="Admin@SecurePass2024!"

# 2FA Configuration
TOTP_SERVICE_NAME="GiftCard Pro"

# File Upload Configuration
UPLOAD_MAX_SIZE="10485760"
UPLOAD_PATH="./uploads"

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
LOGIN_RATE_LIMIT_MAX="5"

# Fraud Detection Configuration
FRAUD_SCORE_THRESHOLD="60"
FRAUD_LOCK_THRESHOLD="80"

# Blockchain Confirmations
TRC20_CONFIRMATIONS="19"

# Security Configuration
BCRYPT_ROUNDS="12"
SESSION_SECRET="gcp_session_secret_2024_secure_random"

# Redis Configuration (for caching and sessions)
REDIS_URL="redis://localhost:6379"

# Logging Configuration
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"
